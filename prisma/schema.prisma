generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  BANNED
}

enum FilmStatus {
  ACTIVE
  HIDDEN
  PENDING
}

enum PersonRole {
  ACTOR
  DIRECTOR
  CINEMATOGRAPHER
  COMPOSER
  EDITOR
  WRITER
  PRODUCER
}

enum ReviewSource {
  TMDB
  IMDB
  REDDIT
  CRITIC_BLOG
  LETTERBOXD
  GUARDIAN
}

model User {
  id                   String                @id @default(cuid())
  name                 String?
  username             String?               @unique
  email                String                @unique
  emailVerified        DateTime?
  image                String?
  bio                  String?
  favoriteGenres       String[]
  password             String?
  role                 UserRole              @default(USER)
  suspendedUntil       DateTime?
  isPublic             Boolean               @default(true)
  publicProfile        Boolean               @default(true)
  allowFollowers       Boolean               @default(true)
  privateGraphs        Boolean               @default(false)
  points               Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  sessions             Session[]
  collections          Collection[]
  feedback             Feedback[]
  userReviews          UserReview[]
  liveReactions        LiveReaction[]
  liveReactionSessions LiveReactionSession[]
  watchlistItems       Watchlist[]
  lastFilmAddedAt      DateTime?
  followers            Follow[]              @relation("following")
  following            Follow[]              @relation("follower")
  announcements        Announcement[]
  addedFilms           Film[]                @relation("addedFilms")
  lists                List[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([email])
}

model Film {
  id                   String                @id @default(cuid())
  tmdbId               Int                   @unique
  imdbId               String?
  title                String
  releaseDate          DateTime?
  runtime              Int?
  synopsis             String?               @db.Text
  posterUrl            String?
  backdropUrl          String?
  genres               String[]
  director             String?
  cast                 Json?
  imdbRating           Float?
  imdbVotes            Int?
  rtCriticsScore       Int?
  rtAudienceScore      Int?
  metacriticScore      Int?
  lastReviewCount      Int                   @default(0)
  nowPlaying           Boolean               @default(false)
  nowPlayingOverride   String?               // null = auto (TMDB), "force_show", "force_hide"
  tickerOverride       String?               // null = auto (nowPlaying), "force_show", "force_hide"
  addedByUserId        String?
  addedByUser          User?                 @relation("addedFilms", fields: [addedByUserId], references: [id])
  isFeatured           Boolean               @default(false)
  pinnedSection        String?
  status               FilmStatus            @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sentimentGraph       SentimentGraph?
  filmBeats            FilmBeats?
  reviews              Review[]
  userReviews          UserReview[]
  liveReactions        LiveReaction[]
  liveReactionSessions LiveReactionSession[]
  featuredFilm         FeaturedFilm?
  watchlistItems       Watchlist[]
  filmPersons          FilmPerson[]
  listFilms            ListFilm[]

  @@index([tmdbId])
  @@index([title])
}

model SentimentGraph {
  id              String   @id @default(cuid())
  filmId          String   @unique
  overallScore    Float
  previousScore   Float?
  anchoredFrom    String
  dataPoints      Json
  peakMoment      Json?
  lowestMoment    Json?
  biggestSwing    String?
  summary         String?  @db.Text
  reviewCount     Int
  sourcesUsed     String[]
  generatedAt     DateTime @default(now())
  varianceSource  String   @default("external_only")
  version         Int      @default(1)
  film            Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
}

model FilmBeats {
  id          String   @id @default(cuid())
  filmId      String   @unique
  beats       Json
  source      String   @default("wikipedia")
  generatedAt DateTime @default(now())
  film        Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@index([filmId])
}

model Review {
  id             String       @id @default(cuid())
  filmId         String
  sourcePlatform ReviewSource
  sourceUrl      String?
  author         String?
  reviewText     String       @db.Text
  sourceRating   Float?
  fetchedAt      DateTime     @default(now())
  contentHash    String?
  film           Film         @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@index([filmId])
  @@index([contentHash])
}

model FeaturedFilm {
  id       String @id @default(cuid())
  filmId   String
  position Int
  film     Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([filmId])
  @@unique([position])
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@index([key])
}

model UserReview {
  id            String   @id @default(cuid())
  userId        String
  filmId        String
  overallRating Float
  beginning     String?  @db.Text
  middle        String?  @db.Text
  ending        String?  @db.Text
  otherThoughts String?  @db.Text
  combinedText  String?  @db.Text
  beatRatings   Json?
  sentiment     Float?
  status        String   @default("approved") // approved, flagged, rejected
  flagReason    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film          Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
  @@index([filmId])
  @@index([status])
}

model LiveReaction {
  id               String               @id @default(cuid())
  userId           String
  filmId           String
  reaction         String
  score            Float
  sessionTimestamp Int
  sessionId        String?
  createdAt        DateTime             @default(now())
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  film             Film                 @relation(fields: [filmId], references: [id], onDelete: Cascade)
  session          LiveReactionSession? @relation(fields: [sessionId], references: [id])

  @@index([filmId])
  @@index([userId, filmId])
  @@index([sessionId])
}

model LiveReactionSession {
  id             String         @id @default(cuid())
  userId         String
  filmId         String
  startedAt      DateTime       @default(now())
  lastReactionAt DateTime
  completionRate Float          @default(0)
  flagged        Boolean        @default(false)
  flagReason     String?
  reactions      LiveReaction[]
  user           User           @relation(fields: [userId], references: [id])
  film           Film           @relation(fields: [filmId], references: [id])

  @@index([userId, filmId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  page      String
  type      String   // "bug", "suggestion", "support", "other"
  message   String   @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  isPublic    Boolean  @default(true)
  filmIds     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  filmId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
  @@index([userId])
  @@index([filmId])
}

model Announcement {
  id        String   @id @default(cuid())
  message   String   @db.VarChar(500)
  pinned    Boolean  @default(true)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pinned])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Person {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  tmdbPersonId       Int          @unique
  profilePath        String?
  biography          String?      @db.Text
  birthday           String?
  deathday           String?
  knownForDepartment String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  films              FilmPerson[]
}

model FilmPerson {
  id        String     @id @default(cuid())
  filmId    String
  personId  String
  role      PersonRole
  character String?
  order     Int?
  film      Film       @relation(fields: [filmId], references: [id], onDelete: Cascade)
  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([filmId, personId, role])
  @@index([filmId])
  @@index([personId])
}

model List {
  id        String     @id @default(cuid())
  name      String
  genreTag  String?
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  films     ListFilm[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ListFilm {
  id      String   @id @default(cuid())
  listId  String
  filmId  String
  list    List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  film    Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([listId, filmId])
}
