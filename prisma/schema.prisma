generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  BANNED
}

enum FilmStatus {
  ACTIVE
  HIDDEN
  PENDING
}

enum ReviewSource {
  TMDB
  IMDB
  REDDIT
  CRITIC_BLOG
  LETTERBOXD
  GUARDIAN
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String       @unique
  emailVerified  DateTime?
  image          String?
  bio            String?
  favoriteGenres String[]
  role           UserRole     @default(USER)
  isPublic       Boolean      @default(true)
  points         Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  accounts       Account[]
  sessions       Session[]
  collections    Collection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Film {
  id              String         @id @default(cuid())
  tmdbId          Int            @unique
  imdbId          String?
  title           String
  releaseDate     DateTime?
  runtime         Int?
  synopsis        String?        @db.Text
  posterUrl       String?
  backdropUrl     String?
  genres          String[]
  director        String?
  cast            Json?
  imdbRating      Float?
  imdbVotes       Int?
  rtCriticsScore  Int?
  rtAudienceScore Int?
  metacriticScore Int?
  isFeatured      Boolean        @default(false)
  status          FilmStatus     @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sentimentGraph  SentimentGraph?
  reviews         Review[]

  @@index([tmdbId])
  @@index([title])
}

model SentimentGraph {
  id              String   @id @default(cuid())
  filmId          String   @unique
  overallScore    Float
  anchoredFrom    String
  dataPoints      Json
  peakMoment      Json?
  lowestMoment    Json?
  biggestSwing    String?
  summary         String?  @db.Text
  reviewCount     Int
  sourcesUsed     String[]
  generatedAt     DateTime @default(now())
  version         Int      @default(1)
  film            Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
}

model Review {
  id             String       @id @default(cuid())
  filmId         String
  sourcePlatform ReviewSource
  sourceUrl      String?
  author         String?
  reviewText     String       @db.Text
  sourceRating   Float?
  fetchedAt      DateTime     @default(now())
  contentHash    String?
  film           Film         @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@index([filmId])
  @@index([contentHash])
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  isPublic    Boolean  @default(true)
  filmIds     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
