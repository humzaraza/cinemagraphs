# Database (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (for NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# TMDB
TMDB_API_KEY=""
TMDB_BASE_URL="https://api.themoviedb.org/3"

# OMDB (for RT + Metacritic scores)
OMDB_API_KEY=""

# Anthropic (for NLP sentiment analysis)
ANTHROPIC_API_KEY=""
CINEMA_ANTHROPIC_KEY=""  # Optional fallback for ANTHROPIC_API_KEY

# RapidAPI (for IMDb reviews)
RAPIDAPI_KEY=""
RAPIDAPI_IMDB_HOST="imdb232.p.rapidapi.com"

# The Guardian (free tier — defaults to "test" if omitted)
GUARDIAN_API_KEY="test"

# Reddit (optional — pending approval)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Apify (optional — fallback for Reddit reviews if official API not available)
# Get your token at https://console.apify.com/account/integrations
# Uses the apify/reddit-scraper actor to search r/movies, r/TrueFilm, r/flicks
APIFY_API_TOKEN=""

# Apple Sign In
APPLE_ID=""
APPLE_SECRET=""

# Resend (for email verification OTP)
RESEND_API_KEY=""

# Vercel KV (Redis cache — optional, falls back to direct DB queries)
# Create at https://vercel.com/dashboard/stores → KV → Create Database
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

CRON_SECRET=

# Neon API credentials for integration tests (3b.3)
# Obtain from https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=
NEON_ORG_ID=
NEON_PROJECT_ID=proud-waterfall-42755951
